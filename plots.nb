Cell[BoxData[
 RowBox[{
  RowBox[{"getData", "[", "directory_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "name", ",", "names", ",", "temp", ",", "flag", ",", "coefficients", ",",
       "objective", ",", 
      RowBox[{"result", "=", 
       RowBox[{"{", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"directory", "//", "SetDirectory"}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"names", "=", " ", 
      RowBox[{"FileNames", "[", "\"\<*_out\>\"", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"temp", "=", 
         RowBox[{
          RowBox[{"FileNameJoin", "[", 
           RowBox[{"{", 
            RowBox[{"directory", ",", "name", ",", "\"\<description.wl\>\""}],
             "}"}], "]"}], "//", "Get"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"FileNameJoin", "[", 
           RowBox[{"{", 
            RowBox[{"directory", ",", "name", ",", "\"\<out.txt\>\""}], "}"}],
            "]"}], "//", "Get"}], "//", "Quiet"}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
          "terminateReason", "==", 
           "\"\<found primal-dual optimal solution\>\""}], ",", 
          RowBox[{"flag", "=", "True"}], ",", 
          RowBox[{"flag", "=", "False"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"flag", "\[Equal]", "True"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"coefficients", "=", 
            RowBox[{"getCoefficients", "[", 
             RowBox[{"FileNameJoin", "[", 
              RowBox[{"{", 
               RowBox[{"directory", ",", "name", ",", "\"\<y.txt\>\""}], 
               "}"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"objective", "=", "primalObjective"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"AppendTo", "[", 
            RowBox[{"result", ",", 
             RowBox[{"{", 
              RowBox[{"temp", ",", "objective", ",", "coefficients"}], 
              "}"}]}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"name", ",", "names"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", "result"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "]"}]}]], "Input",
