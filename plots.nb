Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"converts", " ", "the", " ", "notation", " ", "1.1", "e"}], "-", 
    RowBox[{
    "5", " ", "into", " ", "the", " ", "Mathematica", " ", "format"}]}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"SetAttributes", "[", 
     RowBox[{"convertE", ",", "Listable"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"convertE", "[", "expression_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"exponent", ",", "basis", ",", "temp", ",", "out"}], "}"}], 
      ",", "\n", 
      RowBox[{
       RowBox[{"temp", "=", 
        RowBox[{"Coefficient", "[", 
         RowBox[{"expression", ",", "e"}], "]"}]}], ";", "\n", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"temp", "==", "0"}], ",", 
         RowBox[{"out", "=", "expression"}], ",", "\n", "\n", 
         RowBox[{
          RowBox[{"exponent", "=", 
           RowBox[{"expression", "/.", 
            RowBox[{"e", "->", "0"}]}]}], ";", "\n", 
          RowBox[{"basis", "=", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"expression", "-", "exponent"}], "//", "Expand"}], 
             ")"}], "/.", 
            RowBox[{"e", "->", "1"}]}]}], ";", "\n", 
          RowBox[{"out", "=", 
           RowBox[{"basis", " ", 
            RowBox[{"10", "^", "exponent"}]}]}]}]}], "]"}], ";", "\n", "\n", 
       "out"}]}], "\n", "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.825755066650898*^9, 3.825755092571968*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"70fbbf47-f1c1-48e9-a387-66ebd910af42"],

Cell[BoxData[
 RowBox[{
  RowBox[{"getCoefficients", "[", "file_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"data", ",", "test", ",", "coefficients"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"data", "=", 
      RowBox[{"file", "//", "OpenRead"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"test", "=", "\"\<\>\""}], ";", "\[IndentingNewLine]", 
     RowBox[{"coefficients", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"Not", "[", 
        RowBox[{"test", "===", "EndOfFile"}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"test", "=", 
         RowBox[{"data", "//", "ReadLine"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"coefficients", ",", "test"}], "]"}]}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"file", "//", "Close"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"coefficients", "[", 
        RowBox[{"[", 
         RowBox[{"2", ";;", 
          RowBox[{"-", "2"}]}], "]"}], "]"}], "//", "ToExpression"}], "//", 
      "convertE"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
